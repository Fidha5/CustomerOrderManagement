# Application
NODE_ENV=development
PORT=3000

# Cloud Functions (set to 'true' when deploying to Firebase Cloud Functions)
CLOUD_FUNCTIONS=false

# Database - Choose one based on environment:

# For local development with PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/customer_order_db?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/customer_order_db?schema=public"

# For Cloud SQL (when deployed to Firebase)
# DATABASE_URL="prisma://aws.connect.psdb.cloud/<your-project-id>?pgbouncer=true&connection_limit=10&pool_timeout=20&schema=public"
# DIRECT_URL="postgres://<username>:<password>@<project-id>:<region>:<instance-id>/<db-name>?schema=public&pgbouncer=true"

# OR for local SQLite (not recommended for production)
# DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=15d

# CORS
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173