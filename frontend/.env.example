# API Configuration
# For local development (with backend on localhost:3000)
VITE_API_URL=http://localhost:3000/api

# For Firebase deployment (Cloud Functions)
# Format: https://REGION-PROJECT_ID.cloudfunctions.net/api
# Example: VITE_API_URL=https://us-central1-my-project.cloudfunctions.net/api
# VITE_API_URL=https://us-central1-your-project-id.cloudfunctions.net/api

# For Firebase Hosting with rewrites (same domain)
# VITE_API_URL=/api

# For development with CORS
# VITE_API_URL=http://localhost:3000/api
